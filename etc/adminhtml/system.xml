<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="kkkonrad" translate="label" sortOrder="300">
            <label>Kkkonrad</label>
        </tab>
        <section id="kkkonrad_rma" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
            <tab>kkkonrad</tab>
            <label>RMA Settings</label>
            <resource>Kkkonrad_Rma::config</resource>

            <group id="general" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable RMA</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="return_window_days" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Return Window (Days)</label>
                    <comment>Number of days from invoice date during which a return can be requested.</comment>
                    <validate>required-entry validate-greater-than-zero validate-digits</validate>
                </field>
                <field id="max_file_size_mb" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Max Attachment Size (MB)</label>
                    <comment>Maximum size of a single uploaded file.</comment>
                    <validate>required-entry validate-greater-than-zero validate-digits</validate>
                </field>
                <field id="allowed_file_extensions" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Allowed File Extensions</label>
                    <comment>Comma-separated list, e.g.: jpg,jpeg,png,gif,pdf</comment>
                </field>
                <field id="allowed_order_statuses" translate="label comment" type="multiselect" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Allowed Order Statuses for Return</label>
                    <comment>Select order statuses for which customer can request a return. Leave blank to allow complete orders only.</comment>
                    <source_model>Magento\Sales\Model\Config\Source\Order\Status</source_model>
                </field>
                <!-- Allow customer to cancel their own RMA request -->
                <field id="customers_can_cancel_rma" translate="label comment" type="select" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Allow Customers to Cancel Their RMA</label>
                    <comment>When enabled, customers can cancel their own return request from the account page (only non-terminal statuses).</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <!-- Products excluded from RMA by SKU -->
                <field id="excluded_skus" translate="label comment" type="textarea" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Excluded Product SKUs</label>
                    <comment>Comma-separated list of product SKUs that cannot be returned (e.g. GIFT-CARD,DOWNLOAD-123). Leave empty for no exclusions.</comment>
                </field>
                <!-- Custom CSS for frontend customization -->
                <field id="custom_css" translate="label comment" type="textarea" sortOrder="80" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Custom CSS</label>
                    <comment>Natively injected CSS styles on all customer-facing RMA pages.</comment>
                </field>
                <!-- Custom JS for frontend scripts (analytics/custom actions) -->
                <field id="custom_js" translate="label comment" type="textarea" sortOrder="90" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Custom JavaScript</label>
                    <comment>Natively injected script/code on all customer-facing RMA pages.</comment>
                </field>
                <!-- Allow Guest RMA returns -->
                <field id="allow_guest_rma" translate="label comment" type="select" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Allow Guest Returns (RMA)</label>
                    <comment>Enable to allow guest checkout orders to request and manage returns without logging in.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <!-- Terms and Conditions -->
                <field id="terms_enabled" translate="label comment" type="select" sortOrder="110" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Require Terms and Conditions</label>
                    <comment>Require customers to accept Terms and Conditions before creating RMA.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="terms_cms_page" translate="label comment" type="select" sortOrder="120" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Terms and Conditions CMS Page</label>
                    <comment>Select the page that contains terms and conditions for returns.</comment>
                    <source_model>Magento\Cms\Model\Config\Source\Page</source_model>
                    <depends>
                        <field id="terms_enabled">1</field>
                    </depends>
                </field>
                <!-- Excluded Customer Groups -->
                <field id="excluded_customer_groups" translate="label comment" type="multiselect" sortOrder="130" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Excluded Customer Groups</label>
                    <comment>Select customer groups that are NOT allowed to create RMA requests.</comment>
                    <source_model>Magento\Customer\Model\Config\Source\Group\Multiselect</source_model>
                </field>
            </group>




            <group id="email" translate="label" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Email Notifications</label>
                <field id="sender" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Email Sender</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Identity</source_model>
                </field>
                <field id="created_template" translate="label" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>RMA Created Email Template</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Template</source_model>
                </field>
                <field id="status_changed_template" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Status Changed Email Template</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Template</source_model>
                </field>
                <field id="label_uploaded_template" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Shipping Label Uploaded Email Template</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Template</source_model>
                </field>
                <!-- Fix 8: Admin notification on new RMA -->
                <field id="admin_notification_email" translate="label comment" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Admin Notification Email</label>
                    <comment>Email address to notify when a new RMA is created. Leave empty to disable.</comment>
                    <validate>validate-email</validate>
                </field>
                <field id="admin_notification_template" translate="label" type="select" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Admin Notification Email Template</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Template</source_model>
                </field>
                <!-- Fix 9: Customer notification when admin sends a message -->
                <field id="message_added_template" translate="label" type="select" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>New Message Notification Template (to Customer)</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Template</source_model>
                </field>
            </group>

            <group id="automation" translate="label" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Automation</label>
                <field id="auto_cancel_days" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Auto-Cancel After (Days)</label>
                    <comment>Cancel RMAs with no customer response after this many days. Set to 0 to disable.</comment>
                    <validate>validate-digits</validate>
                </field>
            </group>
        </section>
    </system>
</config>
