type Query {
    """
    Returns the list of RMAs for the currently authenticated customer.
    """
    customerRmas(
        pageSize: Int = 10
        currentPage: Int = 1
    ): CustomerRmaOutput @resolver(class: "Kkkonrad\\Rma\\Model\\Resolver\\CustomerRmaList") @doc(description: "Returns RMA list for the current customer") @cache(cacheIdentity: "Kkkonrad\\Rma\\Model\\Resolver\\Cache\\CustomerRmaListIdentity")

    """
    Returns a single RMA by ID. Customer can only access their own RMAs.
    """
    customerRma(rma_id: Int!): RmaDetails @resolver(class: "Kkkonrad\\Rma\\Model\\Resolver\\CustomerRma") @doc(description: "Returns a single RMA for the current customer")

    """
    Returns active return reasons dictionary.
    """
    rmaReasons: [RmaReasonOption!]! @resolver(class: "Kkkonrad\\Rma\\Model\\Resolver\\RmaReasons") @doc(description: "Returns active return reasons dictionary")

    """
    Returns active item conditions dictionary.
    """
    rmaConditions: [RmaConditionOption!]! @resolver(class: "Kkkonrad\\Rma\\Model\\Resolver\\RmaConditions") @doc(description: "Returns active item conditions dictionary")
}

type CustomerRmaOutput @doc(description: "Paginated list of customer RMAs") {
    items: [RmaSummary]! @doc(description: "List of RMAs")
    total_count: Int! @doc(description: "Total number of RMAs")
    page_info: SearchResultPageInfo @doc(description: "Pagination info")
}

type RmaSummary @doc(description: "Basic RMA data for list view") {
    rma_id: Int! @doc(description: "RMA entity ID")
    increment_id: String! @doc(description: "Human-readable RMA number (e.g. RMA-000001)")
    order_increment_id: String! @doc(description: "Related order number")
    status: String! @doc(description: "Current RMA status code")
    status_label: String! @doc(description: "Human-readable status label")
    resolution_type: String! @doc(description: "Desired resolution (refund, exchange, repair, voucher)")
    created_at: String! @doc(description: "Creation date ISO 8601")
    updated_at: String @doc(description: "Last update date ISO 8601")
}

type RmaDetails @doc(description: "Full RMA detail including items and messages") {
    rma_id: Int! @doc(description: "RMA entity ID")
    increment_id: String! @doc(description: "Human-readable RMA number")
    order_id: Int! @doc(description: "Related order entity ID")
    order_increment_id: String! @doc(description: "Related order number")
    status: String! @doc(description: "Current RMA status code")
    status_label: String! @doc(description: "Human-readable status label")
    resolution_type: String! @doc(description: "Desired resolution")
    comment: String @doc(description: "Customer comment")
    created_at: String! @doc(description: "Creation date ISO 8601")
    updated_at: String @doc(description: "Last update date ISO 8601")
    items: [RmaItem]! @doc(description: "Return items")
    messages: [RmaMessage]! @doc(description: "Thread messages")
    status_history: [RmaStatusHistory]! @doc(description: "Status change log")
    attachments: [RmaAttachment]! @doc(description: "Uploaded files")
    shipping_label_url: String @doc(description: "Authenticated download URL for return shipping label PDF uploaded by admin")
}

type RmaItem @doc(description: "Single item in an RMA request") {
    rma_item_id: Int! @doc(description: "Item entity ID")
    order_item_id: Int! @doc(description: "Related order item entity ID")
    qty: Float! @doc(description: "Quantity being returned")
    reason_id: Int @doc(description: "Return reason entity ID")
    condition_id: Int @doc(description: "Item condition entity ID")
    product_name: String @doc(description: "Product name at time of return")
    product_sku: String @doc(description: "Product SKU at time of return")
    unit_price: Float @doc(description: "Unit price at time of order")
}

type RmaMessage @doc(description: "Message in the RMA communication thread") {
    message_id: Int! @doc(description: "Message entity ID")
    message: String! @doc(description: "Message text")
    author_type: String! @doc(description: "Who sent the message: customer | admin | system")
    author_name: String @doc(description: "Author display name")
    is_internal: Boolean! @doc(description: "Whether the message is internal (admin-only)")
    created_at: String! @doc(description: "Timestamp ISO 8601")
}

type RmaStatusHistory @doc(description: "Record of an RMA status change") {
    history_id: Int! @doc(description: "History entry entity ID")
    status_from: String @doc(description: "Previous status code")
    status_to: String! @doc(description: "New status code")
    comment: String @doc(description: "Optional comment")
    changed_by: String! @doc(description: "Who changed the status: admin | customer | system")
    created_at: String! @doc(description: "Timestamp ISO 8601")
}

type RmaAttachment @doc(description: "File attached to an RMA") {
    attachment_id: Int! @doc(description: "Attachment entity ID")
    file_name: String! @doc(description: "Original file name")
    file_size: Int! @doc(description: "File size in bytes")
    mime_type: String! @doc(description: "MIME type")
    url: String! @doc(description: "Authenticated download URL")
}

type RmaReasonOption @doc(description: "Return reason option") {
    reason_id: Int! @doc(description: "Reason option ID")
    label: String! @doc(description: "Display label")
    code: String! @doc(description: "Unique string code")
}

type RmaConditionOption @doc(description: "Item condition option") {
    condition_id: Int! @doc(description: "Condition option ID")
    label: String! @doc(description: "Display label")
    code: String! @doc(description: "Unique string code")
}

type Mutation {
    createCustomerRma(input: CreateCustomerRmaInput!): CreateCustomerRmaOutput @resolver(class: "Kkkonrad\\Rma\\Model\\Resolver\\CreateCustomerRma") @doc(description: "Creates a new customer RMA request")
    addCustomerRmaMessage(input: AddCustomerRmaMessageInput!): AddCustomerRmaMessageOutput @resolver(class: "Kkkonrad\\Rma\\Model\\Resolver\\AddCustomerRmaMessage") @doc(description: "Adds a new message to the RMA conversation thread")
}

input CreateCustomerRmaInput @doc(description: "Input fields for creating a customer RMA request") {
    order_id: Int! @doc(description: "Order entity ID")
    resolution_type: String! @doc(description: "Desired resolution (refund, exchange, repair, voucher)")
    comment: String @doc(description: "Optional customer comment")
    terms_accepted: Boolean! @doc(description: "Whether the customer accepted the return terms")
    items: [CreateCustomerRmaItemInput!]! @doc(description: "Items to return")
}

input CreateCustomerRmaItemInput @doc(description: "Input fields for item in customer RMA request") {
    order_item_id: Int! @doc(description: "Order item entity ID")
    qty: Float! @doc(description: "Quantity to return")
    reason_id: Int! @doc(description: "Reason ID from rmaReasons")
    condition_id: Int! @doc(description: "Condition ID from rmaConditions")
}

type CreateCustomerRmaOutput @doc(description: "Output after creating customer RMA") {
    rma: RmaDetails! @doc(description: "The created RMA details")
}

input AddCustomerRmaMessageInput @doc(description: "Input fields for adding a message to RMA thread") {
    rma_id: Int! @doc(description: "RMA entity ID")
    message: String! @doc(description: "Message content")
}

type AddCustomerRmaMessageOutput @doc(description: "Output after adding a message to RMA thread") {
    message: RmaMessage! @doc(description: "The created message details")
}
