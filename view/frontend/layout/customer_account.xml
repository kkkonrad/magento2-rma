<?xml version="1.0"?>
<!-- Adds "My Returns" link to the customer account navigation sidebar -->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="customer_account_navigation">
            <block class="Magento\Framework\View\Element\Html\Link\Current"
                   name="customer-account-navigation-rma-link"
                   sortOrder="200">
                <arguments>
                    <argument name="label" xsi:type="string" translate="true">My Returns</argument>
                    <argument name="path" xsi:type="string">rma/index/index</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
