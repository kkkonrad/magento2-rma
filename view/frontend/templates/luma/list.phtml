<?php
declare(strict_types=1);

/** @var \Kkkonrad\Rma\Block\Customer\Rma\ListRma $block */
/** @var \Magento\Framework\Escaper $escaper */
$rmaList = $block->getRmaList();
?>
<div class="rma-luma">
    <div class="actions-toolbar rma-actions"><div class="primary"><a class="action primary" href="<?= $escaper->escapeUrl($block->getCreateUrl()) ?>"><span><?= $escaper->escapeHtml(__('Request a Return')) ?></span></a></div></div>
    <?php if (!$rmaList): ?>
        <div class="message info empty"><span><?= $escaper->escapeHtml(__('No return requests yet')) ?></span></div>
    <?php else: ?>
        <div class="table-wrapper">
            <table class="data table table-rma-items">
                <caption class="table-caption"><?= $escaper->escapeHtml(__('My Returns (RMA)')) ?></caption>
                <thead><tr>
                    <th scope="col" class="col id"><?= $escaper->escapeHtml(__('RMA #')) ?></th>
                    <th scope="col" class="col order"><?= $escaper->escapeHtml(__('Order #')) ?></th>
                    <th scope="col" class="col status"><?= $escaper->escapeHtml(__('Status')) ?></th>
                    <th scope="col" class="col resolution"><?= $escaper->escapeHtml(__('Resolution')) ?></th>
                    <th scope="col" class="col date"><?= $escaper->escapeHtml(__('Date')) ?></th>
                    <th scope="col" class="col actions"><?= $escaper->escapeHtml(__('Action')) ?></th>
                </tr></thead>
                <tbody>
                <?php foreach ($rmaList as $rma): ?>
                    <tr>
                        <td data-th="<?= $escaper->escapeHtmlAttr(__('RMA #')) ?>" class="col id"><?= $escaper->escapeHtml($rma->getIncrementId()) ?></td>
                        <td data-th="<?= $escaper->escapeHtmlAttr(__('Order #')) ?>" class="col order"><?= $escaper->escapeHtml($rma->getOrderIncrementId() ?: '-') ?></td>
                        <td data-th="<?= $escaper->escapeHtmlAttr(__('Status')) ?>" class="col status"><?= $escaper->escapeHtml($block->getStatusLabel($rma->getStatus())) ?></td>
                        <td data-th="<?= $escaper->escapeHtmlAttr(__('Resolution')) ?>" class="col resolution"><?= $escaper->escapeHtml($block->getResolutionLabel((string) $rma->getResolutionType())) ?></td>
                        <td data-th="<?= $escaper->escapeHtmlAttr(__('Date')) ?>" class="col date"><?= $escaper->escapeHtml($rma->getCreatedAt()) ?></td>
                        <td data-th="<?= $escaper->escapeHtmlAttr(__('Action')) ?>" class="col actions"><a href="<?= $escaper->escapeUrl($block->getViewUrl((int)$rma->getRmaId())) ?>"><?= $escaper->escapeHtml(__('View')) ?></a></td>
                    </tr>
                <?php endforeach; ?>
                </tbody>
            </table>
        </div>
    <?php endif; ?>
</div>
