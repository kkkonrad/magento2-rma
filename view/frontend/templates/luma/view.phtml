<?php
declare(strict_types=1);

/** @var \Kkkonrad\Rma\Block\Customer\Rma\View|\Kkkonrad\Rma\Block\Guest\View $block */
/** @var \Magento\Framework\Escaper $escaper */
$rma = $block->getRma();
if (!$rma) { return; }
$hash = method_exists($block, 'getRmaHash') ? $block->getRmaHash() : '';
?>
<div class="rma-luma">
    <div class="page-title-wrapper"><h1 class="page-title"><span class="base"><?= $escaper->escapeHtml(__('RMA #%1', $rma->getIncrementId())) ?></span></h1></div>
    <div class="block block-rma-summary"><div class="block-title"><strong><?= $escaper->escapeHtml(__('Return Details')) ?></strong></div><div class="block-content"><dl class="rma-summary"><dt><?= $escaper->escapeHtml(__('Order #')) ?></dt><dd><?= $escaper->escapeHtml($rma->getOrderIncrementId()) ?></dd><dt><?= $escaper->escapeHtml(__('Status')) ?></dt><dd><?= $escaper->escapeHtml($block->getStatusLabel($rma->getStatus())) ?></dd><dt><?= $escaper->escapeHtml(__('Resolution')) ?></dt><dd><?= $escaper->escapeHtml(ucfirst((string)$rma->getResolutionType())) ?></dd></dl></div></div>
    <?php if ($block->getAttachments()): ?><div class="block"><div class="block-title"><strong><?= $escaper->escapeHtml(__('Attachments')) ?></strong></div><div class="block-content"><ul><?php foreach ($block->getAttachments() as $attachment): ?><li><a target="_blank" rel="noopener" href="<?= $escaper->escapeUrl($block->getMediaUrl($attachment->getFilePath())) ?>"><?= $escaper->escapeHtml($attachment->getFileName()) ?></a></li><?php endforeach; ?></ul></div></div><?php endif; ?>
    <div class="block block-rma-messages"><div class="block-title"><strong><?= $escaper->escapeHtml(__('Messages')) ?></strong></div><div class="block-content"><?php if (!$block->getMessages()): ?><div class="message info empty"><span><?= $escaper->escapeHtml(__('No messages yet.')) ?></span></div><?php else: ?><ol class="rma-message-list"><?php foreach ($block->getMessages() as $message): ?><li><strong><?= $escaper->escapeHtml($message->getAuthorName() ?: ucfirst($message->getAuthorType())) ?></strong><small><?= $escaper->escapeHtml($message->getCreatedAt()) ?></small><p><?= $escaper->escapeHtml($message->getMessage()) ?></p></li><?php endforeach; ?></ol><?php endif; ?></div></div>
    <div class="message error rma-view-message" hidden><span></span></div>
    <form class="form form-rma-message" action="<?= $escaper->escapeUrl($block->getAddMessageUrl()) ?>" method="post" data-mage-init='<?= $escaper->escapeHtmlAttr(json_encode(['Kkkonrad_Rma/js/luma-action' => []])) ?>'>
        <?= $block->getBlockHtml('formkey') ?><input type="hidden" name="rma_id" value="<?= (int)$rma->getRmaId() ?>"><?php if ($hash): ?><input type="hidden" name="hash" value="<?= $escaper->escapeHtmlAttr($hash) ?>"><?php endif; ?>
        <fieldset class="fieldset"><div class="field required"><label class="label" for="rma-message"><span><?= $escaper->escapeHtml(__('Add Message')) ?></span></label><div class="control"><textarea class="input-text" id="rma-message" name="message" maxlength="5000" required></textarea></div></div></fieldset>
        <div class="actions-toolbar"><div class="primary"><button class="action primary" type="submit"><span><?= $escaper->escapeHtml(__('Send Message')) ?></span></button></div></div>
    </form>
    <?php if ($block->canCustomerCancel()): ?><form class="form form-rma-cancel" action="<?= $escaper->escapeUrl($block->getCancelUrl()) ?>" method="post" data-confirm-message="<?= $escaper->escapeHtmlAttr(__('Are you sure you want to cancel this RMA?')) ?>" data-mage-init='<?= $escaper->escapeHtmlAttr(json_encode(['Kkkonrad_Rma/js/luma-action' => ['confirm' => true]])) ?>'><?= $block->getBlockHtml('formkey') ?><input type="hidden" name="rma_id" value="<?= (int)$rma->getRmaId() ?>"><?php if ($hash): ?><input type="hidden" name="hash" value="<?= $escaper->escapeHtmlAttr($hash) ?>"><?php endif; ?><div class="actions-toolbar"><div class="secondary"><button class="action" type="submit"><span><?= $escaper->escapeHtml(__('Cancel Return')) ?></span></button></div></div></form><?php endif; ?>
</div>
