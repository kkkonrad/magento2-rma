<script>
function initRmaCreate() {
    return {
        // State
        selectedOrderId: '',
        orderItems: [],
        selectedItems: [],
        resolutionType: '',
        comment: '',
        attachments: [],
        isDragging: false,
        isLoadingItems: false,
        isItemsLoaded: false,
        submitting: false,
        successMessage: '',
        errorMessage: '',
        termsEnabled: <?= json_encode($block->isTermsEnabled()) ?>,
        termsAccepted: false,
        reasonsRequireImageMap: <?= json_encode($block->getReasonsRequireImageMap()) ?>,


        init() {
            const root = this.$root;
            this.saveUrl       = root.dataset.saveUrl;
            this.uploadUrl     = root.dataset.uploadUrl;
            this.itemsUrl      = root.dataset.itemsUrl;
            this.baseUrl       = root.dataset.baseUrl;
            this.maxFileSize   = parseInt(root.dataset.maxFileSize, 10);
            this.allowedExts   = root.dataset.allowedExtensions.split(',').map(e => e.trim().toLowerCase());
            this.formKey       = root.dataset.formKey;
        },

        isSubmitting() {
            return this.submitting;
        },

        get submittingClass() {
            return this.submitting ? 'opacity-60 cursor-not-allowed' : '';
        },

        // Order selection
        selectOrder() {
            this.selectedOrderId = this.$el.dataset.orderId;
            this.selectedItems   = [];
            this.orderItems      = [];
            this.isItemsLoaded   = false;
            this.isLoadingItems  = true;
            this.loadOrderItems();
        },

        async loadOrderItems() {
            try {
                const url = this.itemsUrl + '?order_id=' + encodeURIComponent(this.selectedOrderId)
                    + '&form_key=' + encodeURIComponent(this.formKey);
                const resp = await fetch(url, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const data = await resp.json();
                if (data.error) {
                    this.errorMessage = data.message || 'Failed to load order items.';
                    this.orderItems = [];
                } else {
                    this.orderItems = data.items || [];
                }
            } catch (e) {
                this.errorMessage = 'Failed to load order items.';
            } finally {
                this.isLoadingItems = false;
                this.isItemsLoaded  = true;
            }
        },

        // Item selection
        toggleItem() {
            const itemId = parseInt(this.$el.dataset.itemId, 10);
            const idx    = this.selectedItems.findIndex(i => i.order_item_id === itemId);
            if (this.$el.checked) {
                if (idx === -1) {
                    const orderItem = this.orderItems.find(i => i.item_id === itemId);
                    this.selectedItems.push({
                        order_item_id: itemId,
                        qty:           1,
                        max_qty:       orderItem ? orderItem.qty_ordered : 1,
                        reason_id:     '',
                        condition_id:  '',
                    });
                }
            } else {
                if (idx !== -1) this.selectedItems.splice(idx, 1);
            }
        },

        isItemSelected(itemId) {
            return this.selectedItems.some(i => i.order_item_id === itemId);
        },

        getItemData(itemId, field) {
            const item = this.selectedItems.find(i => i.order_item_id === itemId);
            return item ? item[field] : '';
        },

        updateItemQty() {
            const itemId = parseInt(this.$el.dataset.itemId, 10);
            const item   = this.selectedItems.find(i => i.order_item_id === itemId);
            if (item) {
                let qty = hyva.safeParseNumber(this.$el.value);
                if (qty < 1) qty = 1;
                if (qty > item.max_qty) qty = item.max_qty;
                item.qty = qty;
                this.$el.value = qty;
            }
        },

        updateItemReason() {
            const itemId = parseInt(this.$el.dataset.itemId, 10);
            const item   = this.selectedItems.find(i => i.order_item_id === itemId);
            if (item) item.reason_id = this.$el.value;
        },

        updateItemCondition() {
            const itemId = parseInt(this.$el.dataset.itemId, 10);
            const item   = this.selectedItems.find(i => i.order_item_id === itemId);
            if (item) item.condition_id = this.$el.value;
        },

        // Resolution & comment
        setResolutionType() {
            this.resolutionType = this.$el.value;
        },

        setComment() {
            this.comment = this.$el.value;
        },

        setTermsAccepted() {
            this.termsAccepted = this.$el.checked;
        },

        // File handling
        setDragging() {
            this.isDragging = true;
        },
        clearDragging() {
            this.isDragging = false;
        },

        openFilePicker() {
            document.getElementById('rma-file-input').click();
        },

        handleFileSelect() {
            const files = Array.from(this.$el.files);
            this.addFiles(files);
        },

        handleDrop() {
            this.isDragging = false;
            const files = Array.from(this.$event.dataTransfer.files);
            this.addFiles(files);
        },

        addFiles(files) {
            for (const file of files) {
                const ext = file.name.split('.').pop().toLowerCase();
                if (!this.allowedExts.includes(ext)) {
                    this.errorMessage = `File type .${ext} is not allowed.`;
                    continue;
                }
                if (file.size > this.maxFileSize) {
                    this.errorMessage = `File "${file.name}" exceeds the maximum size.`;
                    continue;
                }
                const preview = this.isImageType(file.type) ? URL.createObjectURL(file) : '';
                this.attachments.push({ file, name: file.name, size: file.size, type: file.type, preview });
            }
        },

        isImageFile(fileObj) {
            return this.isImageType(fileObj.type);
        },

        isImageType(mimeType) {
            return mimeType.startsWith('image/');
        },

        removeAttachment() {
            const index = parseInt(this.$el.dataset.index, 10);
            if (this.attachments[index]?.preview) {
                URL.revokeObjectURL(this.attachments[index].preview);
            }
            this.attachments.splice(index, 1);
        },

        formatFileSize(bytes) {
            if (bytes < 1024) return bytes + ' B';
            if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
            return (bytes / 1048576).toFixed(1) + ' MB';
        },

        // Submit
        async submitForm() {
            this.errorMessage   = '';
            this.successMessage = '';

            if (!this.selectedOrderId || this.selectedItems.length === 0 || !this.resolutionType) {
                this.errorMessage = 'Please complete all required fields.';
                return;
            }

            // Terms and Conditions Validation
            if (this.termsEnabled && !this.termsAccepted) {
                this.errorMessage = 'Please accept the Terms and Conditions for returns.';
                return;
            }

            // Reason-Specific Attachment Validation
            let requiresImage = false;
            for (const item of this.selectedItems) {
                if (this.reasonsRequireImageMap.includes(parseInt(item.reason_id, 10))) {
                    requiresImage = true;
                    break;
                }
            }

            if (requiresImage && this.attachments.length === 0) {
                this.errorMessage = 'At least one of your selected return reasons requires photographic verification. Please attach at least one image or document.';
                return;
            }


            this.submitting = true;

            try {
                // Build form data (supports file upload)
                const formData = new FormData();
                formData.append('form_key', this.formKey);
                formData.append('order_id', this.selectedOrderId);
                formData.append('resolution_type', this.resolutionType);
                formData.append('comment', this.comment);
                formData.append('items', JSON.stringify(this.selectedItems));
                formData.append('terms_accepted', this.termsAccepted ? '1' : '0');

                this.attachments.forEach((a, i) => {
                    formData.append(`attachments[${i}]`, a.file, a.name);
                });

                const resp = await fetch(this.saveUrl, {
                    method: 'POST',
                    body:   formData,
                });

                const data = await resp.json();

                if (data.success) {
                    this.successMessage = data.message || 'Return request submitted successfully.';
                    // Redirect to the new RMA view
                    setTimeout(() => {
                        window.location.href = data.redirect_url || (this.baseUrl + 'rma/index/view/rma_id/' + data.rma_id);
                    }, 1500);
                } else {
                    this.errorMessage = data.message || 'An error occurred. Please try again.';
                }
            } catch (e) {
                this.errorMessage = 'Network error. Please try again.';
            } finally {
                this.submitting = false;
            }
        },
    };
}
window.addEventListener('alpine:init', () => Alpine.data('initRmaCreate', initRmaCreate), { once: true });
</script>
