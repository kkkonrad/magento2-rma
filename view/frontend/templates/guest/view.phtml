<script>
function initRmaView() {
    return {
        newMessage:       '',
        messageSent:      false,
        messageError:     '',
        sendingMessage:   false,
        cancelLoading:    false,

        init() {
            this.rmaId          = this.$root.dataset.rmaId;
            this.addMessageUrl  = this.$root.dataset.addMessageUrl;
            this.formKey        = this.$root.dataset.formKey;
            this.cancelUrl      = this.$root.dataset.cancelUrl;
            this.returnUrl      = this.$root.dataset.returnUrl;
            this.accessToken    = this.$root.dataset.accessToken;
        },

        isSendingMessage() {
            return this.sendingMessage;
        },

        isNotCancelLoading() {
            return !this.cancelLoading;
        },

        async cancelRma() {
            if (!window.confirm('<?= $escaper->escapeJs(__('Are you sure you want to cancel this return request? This action cannot be undone.')) ?>')) return;
            this.cancelLoading = true;
            try {
                const response = await fetch(this.cancelUrl, {
                    method: 'POST',
                    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                    body: new URLSearchParams({rma_id: this.rmaId, hash: this.accessToken, form_key: this.formKey})
                });
                const data = await response.json();
                if (data.success) {
                    window.location.href = this.returnUrl;
                    return;
                }
                window.alert(data.message || '<?= $escaper->escapeJs(__('An error occurred.')) ?>');
            } finally {
                this.cancelLoading = false;
            }
        },

        setNewMessage() {
            this.newMessage = this.$el.value;
        },

        async sendMessage() {
            this.messageSent  = false;
            this.messageError = '';

            if (!this.newMessage.trim()) {
                this.messageError = 'Please enter a message.';
                return;
            }

            this.sendingMessage = true;

            try {
                const formData = new FormData();
                formData.append('form_key', this.formKey);
                formData.append('rma_id', this.rmaId);
                formData.append('hash', '<?= $escaper->escapeJs($block->getRmaHash()) ?>');
                formData.append('message', this.newMessage);


                const resp = await fetch(this.addMessageUrl, {
                    method: 'POST',
                    body:   formData,
                });
                const data = await resp.json();

                if (data.success) {
                    this.messageSent = true;
                    this.newMessage  = '';
                    document.getElementById('rma-new-message').value = '';
                    // Reload thread
                    window.location.reload();
                } else {
                    this.messageError = data.message || 'Failed to send message.';
                }
            } catch (e) {
                this.messageError = 'Network error. Please try again.';
            } finally {
                this.sendingMessage = false;
            }
        },
    };
}
window.addEventListener('alpine:init', () => Alpine.data('initRmaView', initRmaView), { once: true });
</script>
