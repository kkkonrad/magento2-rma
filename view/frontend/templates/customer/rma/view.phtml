<script>
function initRmaView() {
    return {
        newMessage:       '',
        messageSent:      false,
        messageError:     '',
        sendingMessage:   false,

        init() {
            this.rmaId          = this.$root.dataset.rmaId;
            this.addMessageUrl  = this.$root.dataset.addMessageUrl;
            this.formKey        = this.$root.dataset.formKey;
        },

        isSendingMessage() {
            return this.sendingMessage;
        },

        setNewMessage() {
            this.newMessage = this.$el.value;
        },

        async sendMessage() {
            this.messageSent  = false;
            this.messageError = '';

            if (!this.newMessage.trim()) {
                this.messageError = 'Please enter a message.';
                return;
            }

            this.sendingMessage = true;

            try {
                const formData = new FormData();
                formData.append('form_key', this.formKey);
                formData.append('rma_id', this.rmaId);
                formData.append('message', this.newMessage);

                const resp = await fetch(this.addMessageUrl, {
                    method: 'POST',
                    body:   formData,
                });
                const data = await resp.json();

                if (data.success) {
                    this.messageSent = true;
                    this.newMessage  = '';
                    document.getElementById('rma-new-message').value = '';
                    // Reload thread
                    window.location.reload();
                } else {
                    this.messageError = data.message || 'Failed to send message.';
                }
            } catch (e) {
                this.messageError = 'Network error. Please try again.';
            } finally {
                this.sendingMessage = false;
            }
        },
    };
}
window.addEventListener('alpine:init', () => Alpine.data('initRmaView', initRmaView), { once: true });
</script>
