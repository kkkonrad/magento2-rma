<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">kkkonrad_rma_policy_form.kkkonrad_rma_policy_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Return Policy</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="save" class="Kkkonrad\Rma\Block\Adminhtml\Rma\Edit\SaveButton"/>
            <button name="delete" class="Kkkonrad\Rma\Block\Adminhtml\Rma\Edit\DeleteButton"/>
            <button name="back" class="Kkkonrad\Rma\Block\Adminhtml\Rma\Edit\BackButton"/>
        </buttons>
        <namespace>kkkonrad_rma_policy_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>kkkonrad_rma_policy_form.kkkonrad_rma_policy_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="kkkonrad_rma_policy_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="kkkonrad_rma/policy/save"/>
        </settings>
        <dataProvider class="Kkkonrad\Rma\Model\Policy\DataProvider" name="kkkonrad_rma_policy_form_data_source">
            <settings>
                <requestFieldName>policy_id</requestFieldName>
                <primaryFieldName>policy_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label translate="true">Policy Information</label>
        </settings>
        <field name="policy_id" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <dataScope>policy_id</dataScope>
            </settings>
        </field>
        <field name="name" sortOrder="10" formElement="input">
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Policy Name</label>
                <dataScope>name</dataScope>
            </settings>
        </field>
        <field name="days_refund" sortOrder="20" formElement="input">
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="validate-greater-than-zero" xsi:type="boolean">true</rule>
                    <rule name="validate-digits" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Days for Refund</label>
                <dataScope>days_refund</dataScope>
            </settings>
        </field>
        <field name="days_exchange" sortOrder="30" formElement="input">
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="validate-greater-than-zero" xsi:type="boolean">true</rule>
                    <rule name="validate-digits" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Days for Exchange</label>
                <dataScope>days_exchange</dataScope>
            </settings>
        </field>
        <field name="days_repair" sortOrder="40" formElement="input">
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="validate-greater-than-zero" xsi:type="boolean">true</rule>
                    <rule name="validate-digits" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Days for Repair</label>
                <dataScope>days_repair</dataScope>
            </settings>
        </field>
        <field name="days_voucher" sortOrder="50" formElement="input">
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="validate-greater-than-zero" xsi:type="boolean">true</rule>
                    <rule name="validate-digits" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Days for Voucher</label>
                <dataScope>days_voucher</dataScope>
            </settings>
        </field>
        <field name="terms_conditions" sortOrder="60" formElement="textarea">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Terms and Conditions</label>
                <dataScope>terms_conditions</dataScope>
            </settings>
        </field>
        <field name="is_active" sortOrder="70" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="number">1</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Is Active</label>
                <dataScope>is_active</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="number">0</map>
                            <map name="true" xsi:type="number">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
    </fieldset>
</form>
