<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">kkkonrad_rma_reason_listing.kkkonrad_rma_reason_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Reason</label>
            </button>
        </buttons>
        <spinner>kkkonrad_rma_reason_columns</spinner>
        <deps>
            <dep>kkkonrad_rma_reason_listing.kkkonrad_rma_reason_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="kkkonrad_rma_reason_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">reason_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Kkkonrad_Rma::reasons_manage</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="kkkonrad_rma_reason_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>reason_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters">
            <filterInput name="label" provider="${ $.parentName }">
                <settings>
                    <label translate="true">Label</label>
                    <dataScope>label</dataScope>
                </settings>
            </filterInput>
            <filterInput name="code" provider="${ $.parentName }">
                <settings>
                    <label translate="true">Code</label>
                    <dataScope>code</dataScope>
                </settings>
            </filterInput>
        </filters>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="kkkonrad_rma_reason_columns">
        <settings>
            <editorConfig>
                <param name="selectProvider" xsi:type="string">kkkonrad_rma_reason_listing.kkkonrad_rma_reason_listing.kkkonrad_rma_reason_columns.ids</param>
                <param name="enabled" xsi:type="boolean">false</param>
                <param name="indexField" xsi:type="string">reason_id</param>
            </editorConfig>
            <childDefaults>
                <param name="fieldAction" xsi:type="array">
                    <item name="provider" xsi:type="string">kkkonrad_rma_reason_listing.kkkonrad_rma_reason_listing.kkkonrad_rma_reason_columns_editor</item>
                    <item name="target" xsi:type="string">startEdit</item>
                    <item name="params" xsi:type="array">
                        <item name="0" xsi:type="string">${ $.$data.rowIndex }</item>
                        <item name="1" xsi:type="boolean">true</item>
                    </item>
                </param>
            </childDefaults>
        </settings>

        <selectionsColumn name="ids">
            <settings>
                <indexField>reason_id</indexField>
            </settings>
        </selectionsColumn>

        <column name="reason_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>

        <column name="label">
            <settings>
                <filter>text</filter>
                <label translate="true">Label</label>
            </settings>
        </column>

        <column name="code">
            <settings>
                <filter>text</filter>
                <label translate="true">Code</label>
            </settings>
        </column>

        <column name="sort_order">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Sort Order</label>
            </settings>
        </column>

        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <filter>select</filter>
                <label translate="true">Is Active</label>
            </settings>
        </column>

        <actionsColumn name="actions" class="Kkkonrad\Rma\Ui\Component\Listing\Column\ReasonActions">
            <settings>
                <indexField>reason_id</indexField>
                <label translate="true">Actions</label>
            </settings>
        </actionsColumn>
    </columns>
</listing>
