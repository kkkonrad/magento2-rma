<script>
function confirmAction(url, message) {
    if (confirm(message)) {
        window.location.href = url;
    }
}

require(['jquery'], function ($) {
    $(document).ready(function () {
        $('#canned_reply_select').on('change', function () {
            var text = $(this).val();
            if (text) {
                var currentVal = $('#rma_message_text').val();
                if (currentVal) {
                    $('#rma_message_text').val(currentVal + "\n" + text);
                } else {
                    $('#rma_message_text').val(text);
                }
                $(this).val('');
            }
        });
    });
});
</script>

